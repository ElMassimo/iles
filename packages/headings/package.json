{
  "name": "@islands/headings",
  "version": "0.10.0-beta.1",
  "homepage": "https://github.com/ElMassimo/iles",
  "bugs": "https://github.com/ElMassimo/iles/issues",
  "author": "Máximo Mussini <maximomussini@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElMassimo/iles"
  },
  "funding": "https://github.com/sponsors/ElMassimo",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "types": "dist/headings.d.ts",
  "exports": {
    ".": "./dist/headings.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp pack src/headings.ts --target node20 --watch",
    "build": "vp pack src/headings.ts --clean --target node20 && tsc --emitDeclarationOnly --noCheck --declaration --outDir dist --skipLibCheck --moduleResolution bundler --module esnext --target esnext --esModuleInterop --resolveJsonModule src/headings.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "dependencies": {
    "hast-util-heading-rank": "^3.0.0",
    "hast-util-to-string": "^3.0.0"
  },
  "devDependencies": {
    "@types/estree": "^1.0.5",
    "iles": "workspace:*",
    "slugo": "^0.4.0",
    "typescript": "^5.6.3",
    "unified": "^11.0.5"
  }
}
