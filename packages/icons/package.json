{
  "name": "@islands/icons",
  "version": "0.10.0-beta.1",
  "homepage": "https://github.com/ElMassimo/iles",
  "bugs": "https://github.com/ElMassimo/iles/issues",
  "author": "Máximo Mussini <maximomussini@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElMassimo/iles"
  },
  "funding": "https://github.com/sponsors/ElMassimo",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "types": "dist/icons.d.ts",
  "exports": {
    ".": "./dist/icons.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack --clean && tsc --emitDeclarationOnly --noCheck --declaration --outDir dist --skipLibCheck --moduleResolution bundler --module esnext --target esnext --esModuleInterop --resolveJsonModule src/icons.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "dependencies": {
    "unplugin-icons": "^0.19.0"
  },
  "peerDependencies": {
    "iles": "workspace:*"
  }
}
