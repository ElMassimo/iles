{
  "name": "iles",
  "version": "0.10.0-beta.1",
  "description": "Vite & Vue powered static site generator with partial hydration",
  "keywords": [
    "islands",
    "ssg",
    "vite",
    "vue"
  ],
  "homepage": "https://github.com/ElMassimo/iles",
  "bugs": {
    "url": "https://github.com/ElMassimo/iles/issues"
  },
  "license": "MIT",
  "author": "Máximo Mussini",
  "bin": {
    "iles": "bin/iles.js"
  },
  "files": [
    "bin",
    "dist",
    "lib",
    "types",
    "config.js",
    "turbo.js",
    "jsx-runtime.js",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/node/index.mjs"
    },
    "./jsx-runtime": "./jsx-runtime.js",
    "./jsx-dev-runtime": "./jsx-runtime.js",
    "./dist/client/*": "./dist/client/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "rm -rf dist && npm run dev:shared && npm run dev:start",
    "dev:start": "run-p dev:client dev:node dev:watch",
    "dev:client": "npm run build:client -- --watch",
    "dev:node": "vp pack --watch",
    "dev:shared": "node scripts/copyShared",
    "dev:watch": "node scripts/watchAndCopy",
    "build": "vp run build:prepare && vp run build:client && vp run build:node",
    "build:prepare": "rm -rf dist && node scripts/copyShared",
    "build:client": "vue-tsc --noEmit -p src/client && tsc -p src/client && node scripts/copyClient",
    "build:node": "vp pack --clean && tsc --emitDeclarationOnly --declaration --outDir dist/node --rootDir src/node --skipLibCheck --moduleResolution bundler --module esnext --target esnext --esModuleInterop --resolveJsonModule src/node/index.ts src/node/plugin/plugin.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "dependencies": {
    "@antfu/install-pkg": "^0.3.3",
    "@islands/hydration": "workspace:^0.10.0-beta.1",
    "@islands/mdx": "workspace:^0.10.0-beta.1",
    "@islands/pages": "workspace:^0.10.0-beta.1",
    "@islands/prerender": "workspace:^0.10.0-beta.1",
    "@nuxt/devalue": "^2.0.2",
    "@unhead/ssr": "^1.9.16",
    "@unhead/vue": "^1.9.16",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/devtools-api": "^7.6.3",
    "debug": "^4.3.5",
    "deep-equal": "^2.2.3",
    "es-module-lexer": "^1.5.4",
    "fast-glob": "^3.3.2",
    "local-pkg": "^0.5.0",
    "mico-spinner": "^1.4.0",
    "micromatch": "^4.0.7",
    "minimist": "^1.2.8",
    "pathe": "^1.1.2",
    "picocolors": "^1.0.1",
    "unist-util-visit": "^5.0.0",
    "unplugin-vue-components": "^0.27.3",
    "vite": "^8.0.2",
    "vue": "^3.5.12",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/micromatch": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.14.12",
    "@types/unist": "^3.0.2",
    "chokidar": "^3",
    "conventional-changelog-cli": "^5.0.0",
    "enquirer": "^2",
    "execa": "^9",
    "find-up": "7.0.0",
    "fs-extra": "^11",
    "mdast-util-mdx-jsx": "^3.1.2",
    "mdast-util-mdxjs-esm": "^2.0.1",
    "micromatch": "^4.0.7",
    "npm-run-all": "^4.1.5",
    "rolldown": "1.0.0-rc.9",
    "semver": "^7.6.3",
    "tinyglobby": "0.2.6",
    "typescript": "^5.6.3",
    "vfile": "^6.0.2",
    "vite-plugin-solid": "^2.11.11",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
