{
  "name": "@islands/pwa",
  "version": "0.10.0-beta.1",
  "homepage": "https://github.com/ElMassimo/iles",
  "bugs": "https://github.com/ElMassimo/iles/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElMassimo/iles"
  },
  "funding": "https://github.com/sponsors/userquin",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "types": "dist/pwa.d.ts",
  "exports": {
    ".": "./dist/pwa.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp pack src/pwa.ts --target node20 --watch",
    "build": "vp pack src/pwa.ts --clean --target node20 && tsc --emitDeclarationOnly --noCheck --declaration --outDir dist --skipLibCheck --moduleResolution bundler --module esnext --target esnext --esModuleInterop --resolveJsonModule src/pwa.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "dependencies": {
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "iles": "workspace:*"
  },
  "authors": [
    "Joaquín Sánchez <userquin@gmail.com>"
  ]
}
